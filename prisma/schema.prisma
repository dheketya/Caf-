generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider             = "mysql"
  url                  = env("DATABASE_URL")
  relationMode         = "prisma"
}

// ─── Enums ──────────────────────────────────────────────

enum Role {
  PLATFORM_OWNER
  SHOP_OWNER
  MANAGER
  CASHIER
  KITCHEN
}

enum ShopStatus {
  ACTIVE
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  VOIDED
  REFUNDED
}

enum PaymentMethod {
  CASH
  CARD
  QR_EWALLET
  SPLIT
}

enum EntryType {
  INCOME
  EXPENSE
}

enum ExpenseCategory {
  INGREDIENTS
  RENT
  UTILITIES
  SALARIES
  OTHER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  PAID
  PENDING
  UNPAID
}

enum StockAdjustmentType {
  RECEIVE
  WASTAGE
  CORRECTION
  SALE_DEDUCTION
}

// ─── Platform ───────────────────────────────────────────

model PlatformSettings {
  id              String  @id @default(cuid())
  telegramUsername String? @map("telegram_username")
  telegramGroupLink String? @map("telegram_group_link")
  khqrImage       String? @map("khqr_image") @db.LongText // base64 KHQR payment image
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ─── Packages / Plans ───────────────────────────────────

model Package {
  id              String   @id @default(cuid())
  name            String
  description     String?
  saleLimit       Int?     @map("sale_limit") // null = unlimited
  monthlyPrice    Float    @default(0) @map("monthly_price") // 0 = free
  annualPrice     Float    @default(0) @map("annual_price")  // discounted annual
  modules         Json     // list of enabled module keys
  sortOrder       Int      @default(0) @map("sort_order")
  isDefault       Boolean  @default(false) @map("is_default")
  isVisible       Boolean  @default(true) @map("is_visible") // show on registration page
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  shops       Shop[]
  invoices    Invoice[]

  @@map("packages")
}

// ─── Shops ──────────────────────────────────────────────

model Shop {
  id          String     @id @default(cuid())
  shopCode    String?    @unique @map("shop_code") // short code for staff login
  name        String
  logo        String?    @db.LongText
  brandColor  String     @default("#e85d3a") @map("brand_color")
  address     String?
  phone       String?
  currency    String     @default("USD")
  exchangeRate Float     @default(4100) @map("exchange_rate") // USD to KHR rate
  timezone    String     @default("Asia/Phnom_Penh")
  status      ShopStatus @default(ACTIVE)
  billingCycle String    @default("monthly") @map("billing_cycle") // "monthly" | "annual"
  sugarLevels Json?     @map("sugar_levels") // ["0%", "10%", "25%", "50%", "100%"]

  // Loyalty program settings
  loyaltyEnabled       Boolean @default(false) @map("loyalty_enabled")
  loyaltyTarget        Int     @default(10) @map("loyalty_target") // visits needed for reward
  loyaltyDiscountType  String  @default("percentage") @map("loyalty_discount_type") // "percentage" | "fixed"
  loyaltyDiscountValue Float   @default(10) @map("loyalty_discount_value") // e.g. 10 = 10% or $10

  packageId   String     @map("package_id")
  package     Package    @relation(fields: [packageId], references: [id])

  // Plan upgrade request (pending platform owner approval)
  requestedPackageId   String?  @map("requested_package_id")
  requestedBillingCycle String? @map("requested_billing_cycle") // "monthly" | "annual"
  upgradeStatus        String   @default("none") @map("upgrade_status") // "none" | "pending" | "approved" | "rejected"

  // Plan expiration
  planExpiresAt DateTime? @map("plan_expires_at") // null for free plan
  planStartedAt DateTime? @map("plan_started_at")
  lastActiveAt  DateTime? @map("last_active_at") // last time shop user logged in or made a sale

  // Monthly quota tracking
  saleCount       Int      @default(0) @map("sale_count")
  saleCountResetAt DateTime @default(now()) @map("sale_count_reset_at")
  quotaOverride   Int?     @map("quota_override") // temporary override from admin
  quotaOverrideNote String? @map("quota_override_note")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       User[]
  invitations Invitation[]
  products    Product[]
  categories  Category[]
  modifierGroups ModifierGroup[]
  orders      Order[]
  customers   Customer[]
  stockItems  StockItem[]
  financeEntries FinanceEntry[]
  invoices    Invoice[]
  chatMessages ChatMessage[]
  planHistory PlanHistory[]

  @@index([packageId])
  @@map("shops")
}

// ─── Plan History ──────────────────────────────────────
model PlanHistory {
  id            String   @id @default(cuid())
  shopId        String   @map("shop_id")
  shop          Shop     @relation(fields: [shopId], references: [id])
  packageName   String   @map("package_name") // snapshot of package name at the time
  billingCycle  String   @map("billing_cycle") // "monthly" | "annual"
  price         Float    @default(0)
  action        String   // "subscribed" | "upgraded" | "downgraded" | "renewed" | "expired" | "cancelled"
  startDate     DateTime @map("start_date")
  endDate       DateTime? @map("end_date")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([shopId])
  @@map("plan_history")
}

// ─── Users ──────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          Role     @default(CASHIER)
  isActive      Boolean  @default(true) @map("is_active")
  emailVerified DateTime? @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at")

  shopId        String?  @map("shop_id")
  shop          Shop?    @relation(fields: [shopId], references: [id])

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  orders        Order[]
  stockAdjustments StockAdjustment[]
  financeEntries   FinanceEntry[]   @relation("CreatedBy")
  approvedEntries  FinanceEntry[]   @relation("ApprovedBy")
  chatMessages     ChatMessage[]

  @@index([shopId])
  @@map("users")
}

model Invitation {
  id        String       @id @default(cuid())
  email     String
  role      Role
  status    InviteStatus @default(PENDING)
  token     String       @unique

  shopId    String       @map("shop_id")
  shop      Shop         @relation(fields: [shopId], references: [id])

  createdAt DateTime     @default(now()) @map("created_at")
  expiresAt DateTime     @map("expires_at")

  @@index([shopId])
  @@map("invitations")
}

// ─── Products ───────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String
  color     String?
  sortOrder Int       @default(0) @map("sort_order")

  parentId  String?   @map("parent_id")
  parent    Category? @relation("SubCategories", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Category[] @relation("SubCategories")

  shopId    String    @map("shop_id")
  shop      Shop      @relation(fields: [shopId], references: [id])

  products  Product[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  sku         String?
  image       String?
  isActive    Boolean  @default(true) @map("is_active")
  isOutOfStock Boolean @default(false) @map("is_out_of_stock")
  sortOrder   Int      @default(0) @map("sort_order")
  hasSugarLevel Boolean @default(false) @map("has_sugar_level")
  sizes       Json?    // [{name:"S",price:2.50},{name:"M",price:3.00},{name:"L",price:null}] null=unavailable
  discountType  String?  @map("discount_type")  // "percentage" | "fixed" | null = no discount
  discountValue Float?   @map("discount_value") // e.g. 10 = 10% or $10

  categoryId  String?  @map("category_id")
  category    Category? @relation(fields: [categoryId], references: [id])

  shopId      String   @map("shop_id")
  shop        Shop     @relation(fields: [shopId], references: [id])

  orderItems  OrderItem[]
  stockIngredients ProductIngredient[]
  modifierGroups   ProductModifierGroup[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([categoryId])
  @@map("products")
}

model ModifierGroup {
  id        String   @id @default(cuid())
  name      String
  isRequired Boolean @default(false) @map("is_required")

  shopId    String   @map("shop_id")
  shop      Shop     @relation(fields: [shopId], references: [id])

  modifiers Modifier[]
  products  ProductModifierGroup[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@map("modifier_groups")
}

model Modifier {
  id              String        @id @default(cuid())
  name            String
  priceAdjustment Float         @default(0) @map("price_adjustment")

  groupId         String        @map("group_id")
  group           ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  orderItemModifiers OrderItemModifier[]

  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([groupId])
  @@map("modifiers")
}

model ProductModifierGroup {
  productId       String        @map("product_id")
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  modifierGroupId String        @map("modifier_group_id")
  modifierGroup   ModifierGroup @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)

  @@id([productId, modifierGroupId])
  @@index([modifierGroupId])
  @@map("product_modifier_groups")
}

// ─── Customers ──────────────────────────────────────────

model Customer {
  id            String   @id @default(cuid())
  phone         String
  name          String?
  totalVisits   Int      @default(0) @map("total_visits")
  totalSpent    Float    @default(0) @map("total_spent")
  lastVisitAt   DateTime? @map("last_visit_at")
  note          String?

  shopId        String   @map("shop_id")
  shop          Shop     @relation(fields: [shopId], references: [id])

  orders        Order[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([shopId, phone])
  @@index([shopId])
  @@map("customers")
}

// ─── Orders ─────────────────────────────────────────────

model Order {
  id            String        @id @default(cuid())
  orderNumber   Int           @map("order_number")
  status        OrderStatus   @default(PENDING)
  subtotal      Float
  discountType  String?       @map("discount_type") // "percentage" or "fixed"
  discountValue Float?        @map("discount_value")
  discountReason String?      @map("discount_reason")
  taxAmount     Float         @default(0) @map("tax_amount")
  total         Float
  paymentMethod PaymentMethod? @map("payment_method")
  amountTendered Float?       @map("amount_tendered")
  changeAmount  Float?        @map("change_amount")
  notes         String?
  kitchenReady  Boolean       @default(false) @map("kitchen_ready")

  shopId        String        @map("shop_id")
  shop          Shop          @relation(fields: [shopId], references: [id])

  userId        String        @map("user_id")
  user          User          @relation(fields: [userId], references: [id])

  customerId    String?       @map("customer_id")
  customer      Customer?     @relation(fields: [customerId], references: [id])

  items         OrderItem[]

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([userId])
  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice     Float    @map("unit_price")
  originalPrice Float?   @map("original_price") // price before product discount
  total         Float
  notes         String?
  sizeName      String?  @map("size_name")
  sugarLevel    String?  @map("sugar_level")

  orderId   String   @map("order_id")
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String   @map("product_id")
  product   Product  @relation(fields: [productId], references: [id])

  modifiers OrderItemModifier[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderItemModifier {
  id              String    @id @default(cuid())
  priceAdjustment Float     @map("price_adjustment")

  orderItemId     String    @map("order_item_id")
  orderItem       OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierId      String    @map("modifier_id")
  modifier        Modifier  @relation(fields: [modifierId], references: [id])

  @@index([orderItemId])
  @@index([modifierId])
  @@map("order_item_modifiers")
}

// ─── Stock / Inventory ──────────────────────────────────

model StockItem {
  id               String   @id @default(cuid())
  name             String
  unit             String   // g, ml, pcs, kg, etc.
  currentQuantity  Float    @default(0) @map("current_quantity")
  reorderThreshold Float    @default(0) @map("reorder_threshold")
  costPerUnit      Float    @default(0) @map("cost_per_unit")

  shopId           String   @map("shop_id")
  shop             Shop     @relation(fields: [shopId], references: [id])

  adjustments      StockAdjustment[]
  productIngredients ProductIngredient[]

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([shopId])
  @@map("stock_items")
}

model ProductIngredient {
  id          String    @id @default(cuid())
  quantity    Float     // amount of ingredient per 1 product unit

  productId   String    @map("product_id")
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  stockItemId String    @map("stock_item_id")
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])

  @@index([productId])
  @@index([stockItemId])
  @@map("product_ingredients")
}

model StockAdjustment {
  id            String              @id @default(cuid())
  type          StockAdjustmentType
  quantity      Float
  supplierName  String?             @map("supplier_name")
  purchasePrice Float?              @map("purchase_price")
  reason        String?

  stockItemId   String              @map("stock_item_id")
  stockItem     StockItem           @relation(fields: [stockItemId], references: [id])

  userId        String              @map("user_id")
  user          User                @relation(fields: [userId], references: [id])

  createdAt     DateTime            @default(now()) @map("created_at")

  @@index([stockItemId])
  @@index([userId])
  @@map("stock_adjustments")
}

// ─── Income & Expense ───────────────────────────────────

model FinanceEntry {
  id              String          @id @default(cuid())
  type            EntryType
  amount          Float
  category        String?
  expenseCategory ExpenseCategory? @map("expense_category")
  vendorName      String?         @map("vendor_name")
  note            String?
  receiptUrl      String?         @map("receipt_url")
  date            DateTime
  approvalStatus  ApprovalStatus  @default(APPROVED) @map("approval_status")
  paymentMethod   String?         @map("payment_method") // CASH, QR_EWALLET, SPLIT

  shopId          String          @map("shop_id")
  shop            Shop            @relation(fields: [shopId], references: [id])

  createdById     String          @map("created_by_id")
  createdBy       User            @relation("CreatedBy", fields: [createdById], references: [id])

  approvedById    String?         @map("approved_by_id")
  approvedBy      User?           @relation("ApprovedBy", fields: [approvedById], references: [id])

  orderId         String?         @map("order_id") // link to auto-generated income from sale

  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([createdById])
  @@index([approvedById])
  @@map("finance_entries")
}

// ─── Billing ────────────────────────────────────────────

model Invoice {
  id          String        @id @default(cuid())
  amount      Float
  status      InvoiceStatus @default(PENDING)
  note        String?

  shopId      String        @map("shop_id")
  shop        Shop          @relation(fields: [shopId], references: [id])

  packageId   String        @map("package_id")
  package     Package       @relation(fields: [packageId], references: [id])

  paidAt      DateTime?     @map("paid_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([shopId])
  @@index([packageId])
  @@map("invoices")
}

// ─── Chat ───────────────────────────────────────────────

model ChatMessage {
  id          String   @id @default(cuid())
  content     String   @db.Text
  imageUrl    String?  @map("image_url")
  isRead      Boolean  @default(false) @map("is_read")

  shopId      String   @map("shop_id")
  shop        Shop     @relation(fields: [shopId], references: [id])

  senderId    String   @map("sender_id")
  sender      User     @relation(fields: [senderId], references: [id])

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([shopId])
  @@index([senderId])
  @@map("chat_messages")
}
